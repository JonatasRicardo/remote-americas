{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/searches.schema.json",
  "type": "object",
  "required": ["output", "searches"],
  "properties": {
    "output": {
      "type": "object",
      "required": ["reportsDir", "indexFile", "jsonDir"],
      "properties": {
        "reportsDir": { "type": "string", "minLength": 1 },
        "indexFile": { "type": "string", "minLength": 1 },
        "jsonDir": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "searches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "filename",
          "sites",
          "include",
          "exclude",
          "allOf",
          "anyOf",
          "noneOf",
          "maxResults"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "filename": { "type": "string", "minLength": 1 },
          "sites": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "include": { "type": "array", "items": { "type": "string" } },
          "exclude": { "type": "array", "items": { "type": "string" } },
          "allOf": { "type": "array", "items": { "type": "string" } },
          "anyOf": { "type": "array", "items": { "type": "string" } },
          "noneOf": { "type": "array", "items": { "type": "string" } },
          "maxResults": { "type": "integer", "minimum": 1, "maximum": 200 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
